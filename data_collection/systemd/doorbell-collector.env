# /etc/doorbell-collector.env
# Environment file for the doorbell-collector systemd service.
# Copy this file to /etc/doorbell-collector.env on the Raspberry Pi and
# adjust the values to your setup.  Then reload the unit:
#
#   sudo systemctl daemon-reload
#   sudo systemctl restart doorbell-collector

# ---- Trigger mode -----------------------------------------------------------

# Set to --manual-trigger-only to disable ML inference and rely solely on
# MQTT / GPIO triggers.  In this mode MODEL_PATH_ARGS should be left empty.
# Leave empty (default) to use the ML trigger.
#
#   MANUAL_TRIGGER_ARGS=--manual-trigger-only
#
MANUAL_TRIGGER_ARGS=

# ---- Model path (required unless MANUAL_TRIGGER_ARGS=--manual-trigger-only) -

# Absolute path to the trained XGBoost model.
# Set to empty when using --manual-trigger-only.
#
# ML mode (default):
#   MODEL_PATH_ARGS=--model-path /home/pi/doorbell-detector/models/xgboost_model.json
#
# Manual-trigger-only mode:
#   MODEL_PATH_ARGS=
#
MODEL_PATH_ARGS=--model-path /home/pi/doorbell-detector/models/xgboost_model.json

# ---- Required ---------------------------------------------------------------

# Directory where triggered recordings are written
SAVE_DIR=/home/pi/recordings

# ---- Ring buffer & recording ------------------------------------------------

# How many minutes of audio to keep in the rolling ring buffer (float)
BUFFER_MINUTES=5.0

# Seconds of audio to capture *after* a trigger fires
POST_TRIGGER_SECONDS=7.0

# ---- Audio / feature extraction (must match model training params) ----------

# Audio window size in milliseconds
CHUNK_SIZE_MS=500

# Number of MFCC coefficients
N_MFCC=13

# FFT window size for MFCC extraction
N_FFT=512

# ---- ML trigger -------------------------------------------------------------

# XGBoost prediction probability that fires a save (0.0 – 1.0)
THRESHOLD=0.5

# Chunks to discard after startup / stream reset (gives the mic time to settle)
SKIP_CHUNKS=10

# ---- MQTT broker connection (optional) --------------------------------------
# Leave MQTT_ARGS empty to disable MQTT entirely.
#
# Minimal example (any message on the topic triggers):
#   MQTT_ARGS=--mqtt-host 192.168.1.10 --mqtt-topic doorbell/trigger
#
# With a specific payload check:
#   MQTT_ARGS=--mqtt-host 192.168.1.10 --mqtt-port 1883 --mqtt-topic doorbell/trigger --mqtt-trigger-value RING
#
# When using TLS the default port should be changed to 8883:
#   MQTT_ARGS=--mqtt-host 192.168.1.10 --mqtt-port 8883 --mqtt-topic doorbell/trigger
#
MQTT_ARGS=

# ---- MQTT authentication (optional) -----------------------------------------
# Leave MQTT_AUTH_ARGS empty when the broker requires no authentication.
#
# Username + password:
#   MQTT_AUTH_ARGS=--mqtt-username myuser --mqtt-password s3cr3t
#
MQTT_AUTH_ARGS=

# ---- MQTT TLS/SSL (optional) ------------------------------------------------
# Leave MQTT_TLS_ARGS empty when the broker does not use TLS.
#
# Enable TLS with server certificate verification (CA bundle required):
#   MQTT_TLS_ARGS=--mqtt-tls --mqtt-tls-ca /etc/ssl/certs/ca-certificates.crt
#
# Mutual TLS (client certificate + key):
#   MQTT_TLS_ARGS=--mqtt-tls --mqtt-tls-ca /etc/doorbell/ca.crt \
#                 --mqtt-tls-certfile /etc/doorbell/client.crt \
#                 --mqtt-tls-keyfile  /etc/doorbell/client.key
#
# Disable server certificate verification (insecure, not recommended):
#   MQTT_TLS_ARGS=--mqtt-tls --mqtt-tls-insecure
#
MQTT_TLS_ARGS=

# ---- GPIO trigger (optional) ------------------------------------------------
# Leave GPIO_ARGS empty to disable the physical button.
#
# Example: button connected between BCM pin 18 and GND
#   GPIO_ARGS=--gpio-pin 18
#
GPIO_ARGS=
