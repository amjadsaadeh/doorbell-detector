# /etc/doorbell-collector.env
# Environment file for the doorbell-collector systemd service.
# Copy this file to /etc/doorbell-collector.env on the Raspberry Pi and
# adjust the values to your setup.  Then reload the unit:
#
#   sudo systemctl daemon-reload
#   sudo systemctl restart doorbell-collector

# ---- Required ---------------------------------------------------------------

# Absolute path to the trained XGBoost model
MODEL_PATH=/home/pi/doorbell-detector/models/xgboost_model.json

# Directory where triggered recordings are written
SAVE_DIR=/home/pi/recordings

# ---- Ring buffer & recording ------------------------------------------------

# How many minutes of audio to keep in the rolling ring buffer (float)
BUFFER_MINUTES=5.0

# Seconds of audio to capture *after* a trigger fires
POST_TRIGGER_SECONDS=7.0

# ---- ML trigger -------------------------------------------------------------

# XGBoost prediction probability that fires a save (0.0 – 1.0)
THRESHOLD=0.5

# Chunks to discard after startup / stream reset (gives the mic time to settle)
SKIP_CHUNKS=10

# ---- MQTT trigger (optional) ------------------------------------------------
# Leave MQTT_ARGS empty to disable MQTT entirely.
#
# Minimal example (any message on the topic triggers):
#   MQTT_ARGS=--mqtt-host 192.168.1.10 --mqtt-topic doorbell/trigger
#
# With a specific payload check:
#   MQTT_ARGS=--mqtt-host 192.168.1.10 --mqtt-port 1883 --mqtt-topic doorbell/trigger --mqtt-trigger-value RING
#
MQTT_ARGS=

# ---- GPIO trigger (optional) ------------------------------------------------
# Leave GPIO_ARGS empty to disable the physical button.
#
# Example: button connected between BCM pin 18 and GND
#   GPIO_ARGS=--gpio-pin 18
#
GPIO_ARGS=
