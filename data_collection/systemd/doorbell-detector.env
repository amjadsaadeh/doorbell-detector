# /etc/doorbell-detector.env
# Environment file for the doorbell-detector systemd service.
# Copy this file to /etc/doorbell-detector.env on the Raspberry Pi and
# adjust the values to your setup.  Then reload the unit:
#
#   sudo systemctl daemon-reload
#   sudo systemctl restart doorbell-detector
#
# SECURITY: This file may contain MQTT credentials.  Protect it:
#   sudo chown root:root /etc/doorbell-detector.env
#   sudo chmod 600 /etc/doorbell-detector.env

# ---- Required: reference template WAV ----------------------------------------
# Absolute path to a clean recording of your doorbell sound.
# The detector cross-correlates live audio against this file (Phase 2).
# For Phase 1 (capture-loop stub) any valid 16 kHz mono WAV will work.
#
# Example using a test recording from the repo:
#   TEMPLATE=/home/pi/doorbell-detector/tests/data/audio/test_audio.wav
#
TEMPLATE=/home/pi/doorbell-detector/tests/data/audio/test_audio.wav

# ---- Audio input device -------------------------------------------------------
# Substring matched against PyAudio device names.
# Run: python3 -c "import pyaudio; p=pyaudio.PyAudio(); [print(i,p.get_device_info_by_index(i)['name']) for i in range(p.get_device_count())]; p.terminate()"
# to list available devices and find the right substring.
# Current Pi (mic host) uses wm8960-soundcard.
#
DEVICE_NAME=wm8960-soundcard

# ---- Audio capture window ----------------------------------------------------
# Length of each audio chunk read from the microphone, in milliseconds.
# Must match the template duration used for cross-correlation (Phase 2).
#
CHUNK_SIZE_MS=500

# ---- Recording buffer and post-trigger duration ------------------------------
# Pre-trigger buffer in SECONDS (converted to --buffer-minutes internally)
# and post-trigger duration in MINUTES (converted to --post-trigger-seconds internally).
# Default: 3 seconds before trigger, 0.1 minutes (6 seconds) after trigger.
#
BUFFER_SECONDS=3
POST_TRIGGER_MINUTES=0.1

# ---- MQTT notification (Phase 2) -----------------------------------------------
# Set MQTT_HOST to enable MQTT publishing on each detection.
# Leave MQTT_HOST blank (or remove from ExecStart) to run in console-only mode.
#
MQTT_HOST=
MQTT_PORT=1883
MQTT_DETECT_TOPIC=doorbell/detected
# Uncomment and fill in for broker authentication:
# MQTT_USERNAME=
# MQTT_PASSWORD=
#
# For TLS: add --mqtt-tls to ExecStart manually (boolean flag, cannot be toggled via env var alone).
# Optional TLS file paths (only needed if using mutual TLS or a non-system CA):
# MQTT_TLS_CA=
# MQTT_TLS_CERTFILE=
# MQTT_TLS_KEYFILE=
